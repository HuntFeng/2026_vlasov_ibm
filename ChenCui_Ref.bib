@article{gary1992mirror,
    author = {{Gary}, S. Peter},
    title = {The mirror and ion cyclotron anisotropy instabilities},
    journal = {Journal of Geophysical Research: Space Physics},
    volume = {97},
    number = {A6},
    pages = {8519-8529},
    doi = {https://doi.org/10.1029/92JA00299},
    url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/92JA00299},
    eprint = {https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/92JA00299},
    abstract = {The linear dispersion equation for fully electromagnetic waves and instabilities at arbitrary directions of propagation relative to a background magnetic field Bo in a homogeneous Vlasov plasma is solved numerically for bi-Maxwellian particle distributions. For isotropic plasmas the dispersion and damping of the three modes below the proton cyclotron frequency are studied as functions of βi and Te/Ti. The transport ratios of helicity, cross-helicity, Alfvén ratio, compressibility, and parallel compressibility are defined. Under the condition that the proton temperature perpendicular to Bo is greater than the parallel temperature, the growth rates and transport ratios of the mirror instability and the ion cyclotron anisotropy instability are examined and compared. Both the proton parallel compressibility and the proton Alfvén ratio are significantly different for the two growing modes.},
    year = {1992}
}

